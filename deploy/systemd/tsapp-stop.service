[Unit]
Description=TradeSelect — post-market stop

[Service]
Type=oneshot
# No holiday gate on stop — stopping a non-running service is harmless,
# and we want to be sure we never leave it running outside the window.
ExecStart=/bin/systemctl stop tsapp.service
StandardOutput=append:/var/log/tsapp/schedule.log
StandardError=append:/var/log/tsapp/schedule.log
