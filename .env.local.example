# ─────────────────────────────────────────────────────────
# Broker selection
# ─────────────────────────────────────────────────────────
# `paper`  — simulated trading with real NSE prices (default, no setup needed)
# `fyers`  — real orders via Fyers API (requires keys below)
BROKER=paper

# You can also switch the active broker at runtime via /broker page. This is just the default on first boot.

# ─── Fyers (fully supported) ───
# Create app at https://myapi.fyers.in/ → redirect URI http://localhost:2001/api/broker/callback
# FYERS_APP_ID=
# FYERS_SECRET_KEY=

# ─── Tradejini (skeleton — verify endpoints before live use) ───
# Developer docs (last-known): https://developers.tradejini.com
# TRADEJINI_APP_ID=
# TRADEJINI_SECRET_KEY=
# TRADEJINI_API_BASE=https://api.tradejini.com/v1
# TRADEJINI_REDIRECT_URI=http://localhost:2001/api/broker/callback?broker=tradejini

# ─────────────────────────────────────────────────────────
# Fyers API credentials (only needed when BROKER=fyers)
# Create your app at https://myapi.fyers.in/
#   • Redirect URI:  http://localhost:2001/api/broker/callback
#   • Permissions:   Data APIs + Trading APIs
# ─────────────────────────────────────────────────────────
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=http://localhost:2001/api/broker/callback
